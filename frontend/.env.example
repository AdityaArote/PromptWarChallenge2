# ─── Backend API ──────────────────────────────────────────────────────────────
# Leave empty to use Vite's dev proxy (/api -> localhost:8000)
# Set to your Cloud Run URL for production builds
VITE_API_BASE_URL=

# ─── Supabase ─────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Google Maps (JavaScript API key — browser-safe) ──────────────────────────
VITE_MAPS_API_KEY=your-maps-js-api-key
